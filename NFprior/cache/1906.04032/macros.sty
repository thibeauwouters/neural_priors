\newcommand{\bigo}[1]{\mathcal{O}\roundbr{#1}}

% bold fonts for math symbols
\newcommand{\bfx}{\mathbf{x}} % x (input variable)
\newcommand{\bfy}{\mathbf{y}} % y (target variable)
\newcommand{\bfz}{\mathbf{z}} % z (latent variable)
